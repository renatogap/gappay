APP_NAME=skeleton-api
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
ASSETS_URL=http://nginx:8000
URL_FRONT="${APP_URL}"
NOME_SISTEMA="Skeleton Monolítico"

APP_LOCALE=pt-br
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=conexao_padrao
DB_HOST=db
DB_PORT=5432
DB_DATABASE=policia
DB_USERNAME=postgres
DB_PASSWORD=123456789
DB_SCHEMA=skeleton

SEGURANCA_DB_CONNECTION=conexao_seguranca
SEGURANCA_DB_HOST=db
SEGURANCA_DB_PORT=5432
SEGURANCA_DB_DATABASE=policia
SEGURANCA_DB_USERNAME=postgres
SEGURANCA_DB_PASSWORD=123456789
SEGURANCA_DB_SCHEMA=seguranca

#SANCTUM_STATEFUL_DOMAINS='localhost:3000'
SESSION_DOMAIN=localhost

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=minio
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="naoresponda@policiacivil.pa.gov.br"
MAIL_FROM_NAME="${NOME_SISTEMA}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MINIO_ACCESS_KEY_ID=minio
MINIO_SECRET_ACCESS_KEY=12345678
MINIO_DEFAULT_REGION=us-east-1
MINIO_BUCKET=skeleton
MINIO_PORT1=9001
MINIO_PORT2=9002
MINIO_ENDPOINT="http://127.0.0.1:${MINIO_PORT1}"
MINIO_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"
VITE_NOME_SISTEMA="${NOME_SISTEMA}"
VITE_API_URL="${APP_URL}"
VITE_TELA_LOGIN="/login"